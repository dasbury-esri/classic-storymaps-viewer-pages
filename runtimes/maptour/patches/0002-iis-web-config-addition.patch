diff --git a/runtimes/maptour/upstream/MapTour/src/web.config b/runtimes/maptour/upstream/MapTour/src/web.config
new file mode 100644
index 0000000..9519dfe
--- /dev/null
+++ b/runtimes/maptour/upstream/MapTour/src/web.config
