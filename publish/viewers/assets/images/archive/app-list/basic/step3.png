        <img src="https://www.esri.com/is/image/esri/2023-storymap-roadmap?qlt=82&ts=1761862088966&fmt=png-alpha&dpr=off" srcset="https://www.esri.com/is/image/esri/2023-storymap-roadmap?qlt=82&amp;wid=480&amp;ts=1761862088966&amp;fmt=png-alpha&amp;dpr=off 480w,https://www.esri.com/is/image/esri/2023-storymap-roadmap?qlt=82&amp;wid=750&amp;ts=1761862088966&amp;fmt=png-alpha&amp;dpr=off 750w,https://www.esri.com/is/image/esri/2023-storymap-roadmap?qlt=82&amp;wid=1125&amp;ts=1761862088966&amp;fmt=png-alpha&amp;dpr=off 1125w,https://www.esri.com/is/image/esri/2023-storymap-roadmap?qlt=82&amp;wid=1170&amp;ts=1761862088966&amp;fmt=png-alpha&amp;dpr=off 1170w,https://www.esri.com/is/image/esri/2023-storymap-roadmap?qlt=82&amp;wid=1290&amp;ts=1761862088966&amp;fmt=png-alpha&amp;dpr=off 1290w,https://www.esri.com/is/image/esri/2023-storymap-roadmap?qlt=82&amp;wid=1440&amp;ts=1761862088966&amp;fmt=png-alpha&amp;dpr=off 1440w" loading="lazy" class="cmp-image__image" itemprop="contentUrl" width="720" height="405" alt/>
    
    
    
