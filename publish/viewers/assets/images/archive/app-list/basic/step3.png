<!-- secondary -->
		

<!-- tertiary link -->
		



		</div>
	</div>

	<div class="split__image">
		
			<div class="media-split-img">
				
<div data-cmp-is="image" data-cmp-widths="480,750,1125,1170,1290,1440" data-cmp-dmimage data-cmp-src="https://www.esri.com/is/image/esri/2021-storymap-roadmap?qlt=82&amp;wid=%7B.width%7D&amp;ts=1761862089121&amp;fmt=png-alpha&amp;dpr=off" data-asset-id="1d7d7a7f-2650-4a2a-ae19-25bb9d8257dd" data-cmp-filereference="/content/dam/esrisites/en-us/arcgis/products/storymaps-2019/2021-storymap-roadmap.jpg" id="mediasplit-image-v3-16911f8325" data-cmp-hook-image="imageV3" class="cmp-image" itemscope itemtype="http://schema.org/ImageObject">
    
        <img src="https://www.esri.com/is/image/esri/2021-storymap-roadmap?qlt=82&ts=1761862089121&fmt=png-alpha&dpr=off" srcset="https://www.esri.com/is/image/esri/2021-storymap-roadmap?qlt=82&amp;wid=480&amp;ts=1761862089121&amp;fmt=png-alpha&amp;dpr=off 480w,https://www.esri.com/is/image/esri/2021-storymap-roadmap?qlt=82&amp;wid=750&amp;ts=1761862089121&amp;fmt=png-alpha&amp;dpr=off 750w,https://www.esri.com/is/image/esri/2021-storymap-roadmap?qlt=82&amp;wid=1125&amp;ts=1761862089121&amp;fmt=png-alpha&amp;dpr=off 1125w,https://www.esri.com/is/image/esri/2021-storymap-roadmap?qlt=82&amp;wid=1170&amp;ts=1761862089121&amp;fmt=png-alpha&amp;dpr=off 1170w,https://www.esri.com/is/image/esri/2021-storymap-roadmap?qlt=82&amp;wid=1290&amp;ts=1761862089121&amp;fmt=png-alpha&amp;dpr=off 1290w,https://www.esri.com/is/image/esri/2021-storymap-roadmap?qlt=82&amp;wid=1440&amp;ts=1761862089121&amp;fmt=png-alpha&amp;dpr=off 1440w" loading="lazy" class="cmp-image__image" itemprop="contentUrl" width="720" height="405" alt="A graphic displaying three stages of story map creation, each with a screen displaying story maps with toolbars and large colorful imagery "/>
    
    
    
